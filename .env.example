# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Airtable Configuration
# PAT_AIRTABLE: Personal Access Token for Airtable API.
# BASE_ID_AIRTABLE: The ID of your Airtable base (appK4PC79CjakwBo8).
PAT_AIRTABLE=
BASE_ID_AIRTABLE=

# Gemini AI Configuration
# DOULIA_GEMINI_KEY: Your Google Gemini API Key.
DOULIA_GEMINI_KEY=

# Tavily Search API
# TAVILY_KEY: Required for AI-powered web searches and market monitoring.
TAVILY_KEY=
